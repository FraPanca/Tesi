# .env — root del repository, letto da docker-compose.yml per l'interpolazione ${...}.

# TEMPLATE — copia questo file in ".env" e inserisci i valori reali.
# cp .env.example .env

# ATTENZIONE: è un file distinto sia da backend/.env.example sia da gateway/config/.env
# Hanno scopi diversi, ma MQTT_USER/MQTT_PASSWORD devono avere lo STESSO valore in tutti e tre (stesso broker, stesse credenziali).

# Devono corrispondere all'utente creato con:
#   mosquitto_passwd -c mosquitto/config/passwordfile <utente>
MQTT_USER=
MQTT_PASSWORD=

MONGO_ROOT_USER=
MONGO_ROOT_PASSWORD=