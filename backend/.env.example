# SOLO PER ESECUZIONI LOCALI (npm run dev, fuori Docker).
# Il container backend avviato con docker compose NON legge questo file:
# riceve le variabili da docker-compose.yml, valorizzato da .env nella root del repo.
#
# TEMPLATE — copia questo file in ".env" e inserisci i valori reali.
# cp .env.example .env

PORT=3000
MONGO_URI=mongodb://localhost:27017/iot_energy
REDIS_URI=redis://localhost:6379
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USER=
MQTT_PASSWORD=